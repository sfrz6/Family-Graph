# Copy this file to .env and fill in real values for local development.
# Never commit the real .env file - it's already in .gitignore.
# In production (Vercel), set these in Project Settings -> Environment Variables instead.

# Postgres connection string (Neon free tier - see README for setup steps)
DATABASE_URL=

# Shared login codes - pick your own values, these are never read from code
USER_ACCESS_CODE=
ADMIN_ACCESS_CODE=

# Secret used to sign session JWTs - generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# "development" locally, "production" on Vercel - controls the cookie's Secure flag
ENVIRONMENT=development

# Where the frontend is served from - used for CORS. Comma-separate multiple origins.
FRONTEND_URL=http://localhost:5173
